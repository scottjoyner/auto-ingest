# Auto-Ingest Docker Environment Configuration - SSD_4TB Edition
# Updated: 2026-06-11

# === Host path mounted into containers at /nas (now points to SSD) ===
NAS_ROOT=/media/scott/SSD_4TB/metadata
NAS1_ROOT=/media/scott/NAS1
NAS2_ROOT=/media/scott/NAS2

# === Neo4j (running on host at localhost:7687) ===
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledge_graph_2026
NEO4J_DB=neo4j

# === Shared queue for distributed workers ===
DROP_ROOT=/nas/drop

# === Preferred roots by data family (now on SSD) ===
AUDIO_ROOT=/media/scott/SSD_4TB/audio
DASHCAM_ROOT=/media/scott/SSD_4TB/metadata/dashcam
BODYCAM_ROOT=/media/scott/SSD_4TB/metadata/bodycam
TRANSCRIPT_ROOT=/media/scott/SSD_4TB/metadata/audio/transcriptions
LEGACY_DROP_ROOT=/media/scott/SSD_4TB/metadata/incoming/deathstar

# === Scanner roots consumed by run_ingest_all.sh ===
SCAN_ROOTS=/media/scott/SSD_4TB/metadata/dashcam,/media/scott/SSD_4TB/metadata/audio,/media/scott/SSD_4TB/metadata/audio/transcriptions,/media/scott/SSD_4TB/metadata/bodycam

# === LLM (LM Studio on host) ===
CONTENT_OS_LLM_BASE_URL=http://host.docker.internal:1234/v1
CONTENT_OS_LLM_API_KEY=***
CONTENT_OS_LLM_MODEL=local-model
CONTENT_OS_LLM_TEMPERATURE=0.4
CONTENT_OS_LLM_MAX_TOKENS=***
