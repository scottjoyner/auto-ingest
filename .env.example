# Auto-Ingest Docker Environment Configuration (EXAMPLE)
# Copy to .env and customize per host.
# All paths use mount points shared across the Tailscale network.

# === Host path mounted into containers at /nas ===
NAS_ROOT=/media/scott/NAS4
NAS1_ROOT=/media/scott/SSD_4TB
NAS2_ROOT=/media/scott/NAS4/fileserver

# === Neo4j (running on x1-370 Tailscale node) ===
NEO4J_URI=bolt://100.64.43.123:7687
NEO4J_USER=neo4j
# Per-run / per-shell password (highest priority). Leave unset to use the default below.
NEO4J_PASSWORD=
# Machine-wide default the whole pipeline falls back to when NEO4J_PASSWORD is unset.
# This is the single knob that replaces the old inline "knowledge_graph_2026" literal.
NEO4J_PASSWORD_DEFAULT=knowledge_graph_2026
NEO4J_DB=neo4j

# === Shared queue for distributed workers ===
DROP_ROOT=/nas/drop

# === Preferred roots by data family ===
AUDIO_ROOT=/media/scott/SSD_4TB/audio
DASHCAM_ROOT=/media/scott/NAS4/fileserver/dashcam
BODYCAM_ROOT=/media/scott/NAS4/fileserver/bodycam
TRANSCRIPT_ROOT=/media/scott/SSD_4TB/audio/transcriptions
LEGACY_ROOT=/media/scott/NAS4/fileserver

# === Scanner roots consumed by run_ingest_all.sh ===
SCAN_ROOTS=/media/scott/SSD_4TB/audio,/media/scott/NAS4/fileserver/audio,/media/scott/NAS4/fileserver/audio/transcriptions,/media/scott/NAS4/fileserver/bodycam,/media/scott/NAS4/fileserver/dashcam,/media/scott/NAS4/fileserver/dashcam/transcriptions

# === Legacy deathstar drop path visible on x1-370 ===
LEGACY_DROP_ROOT=/media/scott/NAS4/fileserver/incoming/deathstar
YOLO_ROOT=/media/scott/NAS4/fileserver/dashcam/yolo
META_ROOT=/media/scott/NAS4/fileserver/dashcam/metadata

# === Canonical NAS4 root on x1-370 ===
CANONICAL_ROOT=/media/scott/NAS4/fileserver

# === LLM (LM Studio on host) ===
CONTENT_OS_LLM_BASE_URL=http://host.docker.internal:1234/v1
CONTENT_OS_LLM_API_KEY=${CONTENT_OS_LLM_API_KEY}
CONTENT_OS_LLM_MODEL=local-model
CONTENT_OS_LLM_TEMPERATURE=0.4
CONTENT_OS_LLM_MAX_TOKENS=1200
