# Copy this file to .env and customize per host.
# Updated 2026-06-25: All paths now point to NAS3 + SSD_4TB mount points.

# Host path mounted into containers at /nas
NAS_ROOT=/media/scott/NAS3

# Shared queue for distributed workers
DROP_ROOT=/nas/drop

# Preferred roots by data family
AUDIO_ROOT=/media/scott/SSD_4TB/audio
DASHCAM_ROOT=/media/scott/NAS3/fileserver/dashcam
BODYCAM_ROOT=/media/scott/NAS3/fileserver/bodycam
TRANSCRIPT_ROOT=/media/scott/SSD_4TB/audio/transcriptions
LEGACY_ROOT=/media/scott/NAS3/fileserver

# Scanner roots consumed by run_ingest_all.sh / ingest_transcriptsv5_3.py
SCAN_ROOTS=/media/scott/SSD_4TB/audio,/media/scott/NAS3/fileserver/audio,/media/scott/NAS3/fileserver/audio/transcriptions,/media/scott/NAS3/fileserver/bodycam,/media/scott/NAS3/fileserver/dashcam,/media/scott/NAS3/fileserver/dashcam/transcriptions

# Neo4j (running on x1-370 Tailscale node)
NEO4J_URI=bolt://100.64.43.123:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledge_graph_2026
NEO4J_DB=neo4j

# Legacy deathstar drop path visible on x1-370
LEGACY_DROP_ROOT=/media/scott/NAS3/fileserver/incoming/deathstar
YOLO_ROOT=/media/scott/NAS3/fileserver/dashcam/yolo
META_ROOT=/media/scott/NAS3/fileserver/dashcam/metadata

# Canonical NAS3 root on x1-370
CANONICAL_ROOT=/media/scott/NAS3/fileserver
