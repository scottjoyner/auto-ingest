# Copy this file to .env and customize per host.
# Updated 2026-06-25: All paths now point to NAS4 + SSD_4TB mount points.

# Host path mounted into containers at /nas
NAS_ROOT=/media/scott/NAS4

# Shared queue for distributed workers
DROP_ROOT=/nas/drop

# Preferred roots by data family
AUDIO_ROOT=/media/scott/SSD_4TB/audio
DASHCAM_ROOT=/media/scott/NAS4/fileserver/dashcam
BODYCAM_ROOT=/media/scott/NAS4/fileserver/bodycam
HEADCAM_ROOT=/media/scott/NAS4/fileserver/headcam
TRANSCRIPT_ROOT=/media/scott/SSD_4TB/audio/transcriptions
LEGACY_ROOT=/media/scott/NAS4/fileserver

# Scanner roots consumed by run_ingest_all.sh / ingest_transcriptsv5_3.py
SCAN_ROOTS=/media/scott/SSD_4TB/audio,/media/scott/NAS4/fileserver/audio,/media/scott/NAS4/fileserver/audio/transcriptions,/media/scott/NAS4/fileserver/dashcam,/media/scott/NAS4/fileserver/dashcam/transcriptions,/media/scott/NAS4/fileserver/dashcam/metadata,/media/scott/NAS4/fileserver/dashcam/yolo,/media/scott/NAS4/fileserver/bodycam,/media/scott/NAS4/fileserver/headcam

# Neo4j (running on x1-370 Tailscale node)
NEO4J_URI=bolt://100.64.43.123:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledge_graph_2026
NEO4J_DB=neo4j

# Legacy deathstar drop path visible on x1-370
LEGACY_DROP_ROOT=/media/scott/NAS4/fileserver/incoming/deathstar

# Direct pull from deathstar's local 8TB fileserver when the mirror is missing
REMOTE_DROP_HOST=deathstar
REMOTE_DROP_ROOT=/mnt/8TB_2025/fileserver
REMOTE_PULL=1

YOLO_ROOT=/media/scott/NAS4/fileserver/dashcam/yolo
META_ROOT=/media/scott/NAS4/fileserver/dashcam/metadata
NEO4J_BKPS_ROOT=/media/scott/NAS4/fileserver/neo4j-bkps

# Canonical NAS4 root on x1-370
CANONICAL_ROOT=/media/scott/NAS4/fileserver
