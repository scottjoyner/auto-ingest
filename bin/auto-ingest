#!/usr/bin/env python3
"""
Unified `auto-ingest` CLI — one host-agnostic command for the whole pipeline.

Implements the surface described in docs/PROPOSED_RUN_CLI.md:
  auto-ingest status                # graph / preprocessing status
  auto-ingest caps                  # probe hardware + backend profile
  auto-ingest link-speakers [...]   # globally link local Speakers -> GlobalSpeaker
  auto-ingest whoami [...]          # anchor / verify the "me" (Scott) speaker

Credentials come ONLY from the environment / config.yaml (never hardcoded in this file).
Host + fileserver paths are resolved via auto_ingest_config (same logic as the linker).

This is the single entrypoint to launch a global-speaker linking pass. Run with
`--help` on any subcommand for options.
"""
from __future__ import annotations

import argparse
import os
import platform
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Dict

REPO = Path(__file__).resolve().parent.parent
# Put the repo root on the import path so `auto_ingest.*` and the repo-level
# `auto_ingest_config` module resolve regardless of the caller's CWD.
if str(REPO) not in sys.path:
    sys.path.insert(0, str(REPO))
# Canonical linker now lives in the package (W-42). Run it as a module so the
# relative config import resolves from the repo root.
DEFAULT_LINKER_MODULE = "auto_ingest.diarize.link_global_speakers"

# ---------------------------------------------------------------------------
# Neo4j connection (env first, then config.yaml; never hardcoded here)
# ---------------------------------------------------------------------------
def neo4j_env() -> Dict[str, str]:
    try:
        from auto_ingest_config import get_neo4j_config
        cfg = get_neo4j_config() or {}
    except Exception:
        cfg = {}
    env = dict(os.environ)
    env["NEO4J_URI"] = os.environ.get("NEO4J_URI") or cfg.get("uri") or "bolt://localhost:7687"
    env["NEO4J_USER"] = os.environ.get("NEO4J_USER") or cfg.get("user") or "neo4j"
    # Password resolves through auto_ingest_config.get_neo4j_password():
    #   NEO4J_PASSWORD -> config.yaml -> NEO4J_PASSWORD_DEFAULT -> baked default.
    # cfg["password"] is already resolved; only fall back to the resolver here if
    # get_neo4j_config() was unavailable (except branch above).
    pw = os.environ.get("NEO4J_PASSWORD") or cfg.get("password")
    if not pw:
        try:
            from auto_ingest_config import get_neo4j_password
            pw = get_neo4j_password()
        except Exception:
            pw = ""
    env["NEO4J_PASSWORD"] = pw
    env["NEO4J_DB"] = os.environ.get("NEO4J_DB") or "neo4j"
    return env


def _run_module(mod: str, args: list, extra_env: Dict[str, str] | None = None) -> int:
    cmd = [sys.executable, "-u", "-m", mod, *args]
    env = extra_env or neo4j_env()
    print(f"[auto-ingest] $ {' '.join(cmd)}", flush=True)
    return subprocess.call(cmd, cwd=str(REPO), env=env)


def _run(script: str, args: list, extra_env: Dict[str, str] | None = None) -> int:
    """Run a repo-root script/entrypoint (mirror of _run_module for file paths)."""
    target = (REPO / script)
    cmd = [sys.executable, "-u", str(target), *args]
    env = extra_env or neo4j_env()
    print(f"[auto-ingest] $ {' '.join(cmd)}", flush=True)
    return subprocess.call(cmd, cwd=str(REPO), env=env)


# Canonical package modules (post W-42 restructure). Kept as the single source
# of truth so run-all never depends on flat scripts that have been archived.
MODULE_DIARIZE = "auto_ingest.diarize.link_global_speakers"
MODULE_YOLO = "auto_ingest.dashcam.yolo_embeddings"
MODULE_INGEST_TRANSCRIPTS = "auto_ingest.ingest.transcripts"


# ---------------------------------------------------------------------------
# caps
# ---------------------------------------------------------------------------
def cmd_caps(_args) -> int:
    print(f"HOST: {platform.node()}  ({platform.system()} {platform.release()})")
    print(f"CPU:  {platform.processor() or 'n/a'}  cores={os.cpu_count()}")
    nvidia = shutil.which("nvidia-smi")
    rocm = shutil.which("rocminfo")
    if nvidia:
        be = "CUDA"
    elif rocm:
        be = "ROCm"
    elif platform.system() == "Darwin" and platform.processor() == "arm":
        be = "MLX"
    else:
        be = "ONNX (CPU)"
    print(f"GPU backend: {be}")
    print(f"  nvidia-smi: {nvidia or 'absent'}  rocminfo: {rocm or 'absent'}")
    # Single source of truth for compute routing (auto_ingest.backend).
    try:
        from auto_ingest.backend import backend_info
        info = backend_info()
        print(f"  auto_ingest.backend: backend={info['backend']} torch_device={info['torch_device']}"
              f" gpu={info.get('gpu_name') or 'n/a'}"
              f" (cuda={info['cuda_available']} rocm={info['rocm_available']}"
              f" mps={info['mps_available']} mlx={info['mlx_available']} onnx={info['onnx_available']})")
    except Exception as e:
        print(f"  auto_ingest.backend: unavailable ({e})")
    for mod, label in [("torch", "torch"), ("torchaudio", "torchaudio"),
                       ("speechbrain", "speechbrain"), ("pyannote.audio", "pyannote"),
                       ("faiss", "faiss"), ("neo4j", "neo4j")]:
        try:
            __import__(mod)
            ok = "ok"
        except Exception:
            ok = "MISSING"
        print(f"  {label:12s} {ok}")
    return 0


# ---------------------------------------------------------------------------
# status
# ---------------------------------------------------------------------------
def cmd_status(args) -> int:
    try:
        from neo4j import GraphDatabase
    except Exception as e:
        print(f"neo4j driver unavailable: {e}", file=sys.stderr)
        return 1
    env = neo4j_env()
    try:
        d = GraphDatabase.driver(env["NEO4J_URI"], auth=(env["NEO4J_USER"], env["NEO4J_PASSWORD"]))
        with d.session(database=env["NEO4J_DB"]) as s:
            def n(q):
                r = s.run(q).single()
                return r["c"] if r else 0
            sp = n("MATCH (s:Speaker) RETURN count(*) AS c")
            gs = n("MATCH (g:GlobalSpeaker) RETURN count(*) AS c")
            gsc = n("MATCH (g:GlobalSpeaker{status:'confirmed'}) RETURN count(*) AS c")
            edges = n("MATCH (s:Speaker)-[:SAME_PERSON]->(g:GlobalSpeaker) RETURN count(*) AS c")
            linked = n("MATCH (s:Speaker)-[:SAME_PERSON]->() RETURN count(DISTINCT s) AS c")
            me = n("MATCH (s:Speaker{is_me:true}) RETURN count(*) AS c")
            seg = n("MATCH (s:Segment) RETURN count(*) AS c")
            print(f"NEO4J: {env['NEO4J_URI']}  db={env['NEO4J_DB']}")
            print(f"  Speaker        : {sp}")
            print(f"  GlobalSpeaker  : {gs}  (confirmed {gsc}, tentative {gs-gsc})")
            print(f"  SAME_PERSON    : {edges}  (distinct linked Speaker: {linked})")
            print(f"  Speaker is_me  : {me}")
            print(f"  Segment        : {seg}")
            if sp:
                print(f"  linkage coverage: {linked/sp*100:.1f}% of Speaker nodes linked")
        d.close()
    except Exception as e:
        print(f"neo4j query failed: {e}", file=sys.stderr)
        return 1
    return 0


# ---------------------------------------------------------------------------
# claims  (read-only view of active IngestJob claims + stage manifest, G4)
# ---------------------------------------------------------------------------
def cmd_claims(args) -> int:
    """Human-readable view of IngestJob claims and per-key stage progress.

    Read-only: issues only index-backed, LIMIT-bounded queries. Satisfies G4
    (per-source preprocessing manifest visible via one command).
    """
    env = neo4j_env()
    try:
        from neo4j import GraphDatabase
    except Exception as e:
        print(f"neo4j driver unavailable: {e}", file=sys.stderr)
        return 1
    try:
        from auto_ingest import ingest_claim
    except Exception as e:
        print(f"ingest_claim unavailable: {e}", file=sys.stderr)
        return 1
    try:
        d = GraphDatabase.driver(env["NEO4J_URI"],
                                 auth=(env["NEO4J_USER"], env["NEO4J_PASSWORD"]))
        print(f"ACTIVE CLAIMS (ttl={args.ttl_sec}s):")
        claims = ingest_claim.list_claims(d, ttl_sec=args.ttl_sec, limit=args.limit)
        if not claims:
            print("  (none)")
        for c in claims:
            print(f"  {c['key']:32s} owner={c['owner']} status={c['status']} "
                  f"claimed_at={c['claimed_at']}")
        if args.expired:
            print(f"EXPIRED CLAIMS (ttl={args.ttl_sec}s):")
            expired = ingest_claim.expired_claims(d, ttl_sec=args.ttl_sec,
                                                  limit=args.limit)
            if not expired:
                print("  (none)")
            for e in expired:
                print(f"  {e['key']:32s} owner={e['owner']} "
                      f"claimed_at={e['claimed_at']}")
        d.close()
    except Exception as e:
        print(f"neo4j query failed: {e}", file=sys.stderr)
        return 1
    return 0


# ---------------------------------------------------------------------------
# reap  (reaper — clears expired IngestJob claims; bounded + index-backed)
# ---------------------------------------------------------------------------
def cmd_reap(args) -> int:
    env = neo4j_env()
    try:
        from auto_ingest import ingest_claim
        from neo4j import GraphDatabase
    except Exception as e:
        print(f"unavailable: {e}", file=sys.stderr)
        return 1
    try:
        d = GraphDatabase.driver(env["NEO4J_URI"],
                                 auth=(env["NEO4J_USER"], env["NEO4J_PASSWORD"]))
        cleared = ingest_claim.reap(d, ttl_sec=args.ttl_sec, limit=args.limit)
        d.close()
        print(f"reap: cleared {cleared} expired claim(s)")
    except Exception as e:
        print(f"neo4j reap failed: {e}", file=sys.stderr)
        return 1
    return 0


# ---------------------------------------------------------------------------
# link-speakers
# ---------------------------------------------------------------------------
def cmd_link_speakers(args) -> int:
    # Value flags as a dict so --more-aggressive can override in place (no dupes).
    opts = {
        "--global-thresh": "0.78", "--global-k": "8",
        "--source-level": "auto",
        "--min-seg": "0.7", "--max-snips": "8", "--max-per-file": "3", "--snip-len": "1.6",
        "--thresh": "0.72",
        "--holdout-min": "0.62", "--holdout-action": "drop-members",
        "--priority-name": args.priority or "Scott|Kipnerter",
        "--emb-cache": "./emb_cache.sqlite",
        "--audio-index": "./audio_index.json",
        "--audio-cache": "./audio_path_cache.json",
    }
    flags = ["--global-prefilter", "--skip-already-linked", "--holdout"]

    if args.more_aggressive:
        # wider nets (see docs/PROPOSED_RUN_CLI.md "More Aggressive Command")
        opts.update({
            "--global-thresh": "0.74", "--global-k": "16", "--global-m": "48",
            "--global-ef": "256", "--min-seg": "0.6", "--max-snips": "12",
            "--max-per-file": "4", "--snip-len": "2.0", "--min-proportion": "0.4",
            "--min-rms": "0.004", "--min-snr-db": "5.0", "--thresh": "0.68",
            "--holdout-min": "0.58", "--quarantine-min": "0.72",
        })
    if args.faiss:
        opts.update({"--faiss-k": "128", "--faiss-index": "hnsw",
                     "--faiss-m": "48", "--faiss-ef": "256"})
        flags += ["--faiss-prefilter", "--global-include-tentative"]
    if args.limit:
        opts["--limit-speakers"] = str(args.limit)
    if args.max_speakers:
        opts["--max-speakers"] = str(args.max_speakers)
    # rank-and-label is a full-graph aggregation (21M nodes) that can exceed Neo4j's
    # transaction memory; only run it when explicitly requested, ideally as a final pass.
    if args.rank_and_label:
        flags.append("--rank-and-label")
    if args.promote:
        flags.append("--promote")
        if args.promote_min_weight:
            opts["--promote-min-weight"] = str(args.promote_min_weight)
    if args.dry_run:
        flags.append("--dry-run")
    if args.state_file:
        opts["--state-file"] = args.state_file

    cli = list(flags)
    for k, v in opts.items():
        cli += [k, v]
    rc = _run_module(DEFAULT_LINKER_MODULE, cli, extra_env=neo4j_env())
    # N11: re-anchor Scott after every link pass so the canonical "me" GlobalSpeaker
    # cannot fragment again as new clusters are written. (whoami --merge is idempotent;
    # in dry-run we skip the merge so we don't pretend to write, matching --dry-run.)
    if rc == 0 and not args.dry_run:
        merge_cli = ["--merge"]
        if args.dry_run:
            merge_cli = ["--dry-run"]
        _run("scripts/anchor_speaker_me.py", merge_cli, extra_env=neo4j_env())
    return rc


# ---------------------------------------------------------------------------
# whoami  (anchor / verify the "me" speaker)
# ---------------------------------------------------------------------------
def cmd_whoami(args) -> int:
    cli = ["scripts/anchor_speaker_me.py"]
    if args.dry_run:
        cli += ["--dry-run"]
    if args.corpus:
        cli += ["--corpus", args.corpus]
    if args.merge:
        cli += ["--merge"]
    if args.seed:
        cli += ["--seed", args.seed]
    return _run(cli[0], cli[1:], extra_env=neo4j_env())


# ---------------------------------------------------------------------------
# argparse
# ---------------------------------------------------------------------------
def cmd_tiktok(args) -> int:
    if args.nextcloud:
        cli = ["tiktok_shorts.py", "--nextcloud"]
    elif args.source_root:
        cli = ["tiktok_shorts.py", "--source-root", args.source_root]
    else:
        cli = ["tiktok_shorts.py", "--clip", args.clip]
    cli += ["--out", args.out]
    cli += ["--pick", args.pick]
    if args.date:
        cli += ["--date", args.date]
    if args.transcript_json:
        cli += ["--transcript-json", args.transcript_json]
    if args.hook:
        cli += ["--hook", args.hook]
    if args.cta:
        cli += ["--cta", args.cta]
    if args.music:
        cli += ["--music", args.music]
    cli += ["--zoom", str(args.zoom), "--crf", str(args.crf),
            "--max-dur", str(args.max_dur)]
    if args.no_auto_transcript:
        cli.append("--no-auto-transcript")
    return _run(cli[0], cli[1:], extra_env=neo4j_env())


def cmd_shorts(args) -> int:
    """Forward to the research-scripted shorts package CLI."""
    return _run("python3", ["-m", "auto_ingest.shorts.cli"] + args.rest,
                extra_env=neo4j_env())


def cmd_link_concepts(args) -> int:
    """Forward to scripts/link_utterances_to_concepts.py (W-56)."""
    return _run("python3", ["scripts/link_utterances_to_concepts.py"] + args.rest,
                extra_env=neo4j_env())


def cmd_worker(args) -> int:
    return _run("./run_worker.sh", [], extra_env=neo4j_env())


# ---------------------------------------------------------------------------
# ingest  (iPhone movies + pictures -> graph + content)
# ---------------------------------------------------------------------------
def cmd_ingest(args) -> int:
    cli = ["ingest_media.py"]
    if args.root:
        cli += ["--root", args.root]
    if args.nextcloud_url:
        cli += ["--nextcloud-url", args.nextcloud_url]
        if args.nextcloud_user:
            cli += ["--nextcloud-user", args.nextcloud_user]
        if args.nextcloud_pass:
            cli += ["--nextcloud-pass", args.nextcloud_pass]
        cli += ["--nextcloud-root", args.nextcloud_root]
    if args.source:
        cli += ["--source", args.source]
    cli += ["--kind", args.kind]
    if args.state:
        cli += ["--state", args.state]
    if args.limit:
        cli += ["--limit", str(args.limit)]
    if args.no_transcribe:
        cli.append("--no-transcribe")
    if args.no_embed:
        cli.append("--no-embed")
    if args.no_shorts:
        cli.append("--no-shorts")
    if args.music:
        cli += ["--music", args.music]
    if args.slideshow:
        cli.append("--slideshow")
    if args.force:
        cli.append("--force")
    if args.dry_run:
        cli.append("--dry-run")
    return _run(cli[0], cli[1:], extra_env=neo4j_env())


# ---------------------------------------------------------------------------
# run-all  (machine-agnostic orchestration of the full historical ingest pass)
# ---------------------------------------------------------------------------
def cmd_run_all(args) -> int:
    """Chain the historical memory-enrichment pipeline end to end.

    Stages are skipped when their --skip-* flag is set. Credentials and paths
    come exclusively from neo4j_env() / auto_ingest_config, never hardcoded.
    """
    env = neo4j_env()
    rc = 0

    def step(name: str, fn) -> int:
        nonlocal rc
        print(f"\n=== auto-ingest run-all: {name} ===", flush=True)
        r = fn()
        if r != 0:
            rc = r
            print(f"[auto-ingest] WARNING: {name} exited {r} (continuing)", flush=True)
        return r

    if not args.skip_copy:
        step("copy audio/dashcam/bodycam", lambda: (
            _run("./audio_copy.sh", [], env) or
            _run("./dashcam_copy.sh", [], env) or
            _run("./bodycam_copy.sh", [], env)
        ))

    if not args.skip_diarize:
        step("speaker diarization", lambda: _run_module("speakers", [], env))

    if not args.skip_ingest:
        step("ingest transcripts -> Neo4j", lambda: _run("./run_ingest_all.sh", [], env))
        step("reconcile speakers (RTTM -> graph)",
             lambda: _run_module("speakers_reconcile", [
                 "--neo4j-uri", env["NEO4J_URI"], "--neo4j-user", env["NEO4J_USER"],
                 "--neo4j-password", env["NEO4J_PASSWORD"], "--db", env["NEO4J_DB"],
                 "--batch", "50", "--only-missing", "--allow-discovery",
             ], env))

    if not args.skip_classify:
        step("music/lyrics segment classification",
             lambda: _run_module("01_precompute_music_segments", ["--push-neo4j"], env) or
                     _run_module("02_classify_lyrics",
                                 ["--segments-source", "neo4j", "--limit", "50000"], env))

    if not args.skip_link:
        # Delegate to the existing link-speakers orchestration (package linker).
        link = cmd_link_speakers(_link_args(args))
        if link != 0:
            rc = link

    if not args.skip_yolo:
        step("dashcam YOLO embeddings",
             lambda: _run_module(MODULE_YOLO, [
                 "--resume", "--grid", "16x9", "--pyramid", "--heatmap",
                 "--repair-missing-moov",
                 "--neo4j-uri", env["NEO4J_URI"], "--neo4j-user", env["NEO4J_USER"],
                 "--neo4j-pass", env["NEO4J_PASSWORD"], "--win-mins", "10",
             ], env))

    print(f"\n=== auto-ingest run-all complete (rc={rc}) ===", flush=True)
    return rc


def _link_args(args):
    """Build a fake args namespace for cmd_link_speakers from run-all options."""
    class _A:
        pass
    a = _A()
    a.limit = args.limit
    a.max_speakers = args.max_speakers
    a.priority = None
    a.faiss = args.faiss
    a.more_aggressive = args.more_aggressive
    a.rank_and_label = args.rank_and_label
    a.promote = args.promote
    a.promote_min_weight = args.promote_min_weight
    a.dry_run = args.dry_run
    a.state_file = args.state_file or ""
    return a


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="auto-ingest", description="Unified auto-ingest pipeline CLI.")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("caps", help="Probe hardware + backend profile.").set_defaults(func=cmd_caps)

    ps = sub.add_parser("status", help="Show graph / linkage status.")
    ps.add_argument("--source", choices=["dashcam", "audio", "bodycam"], default=None)
    ps.set_defaults(func=cmd_status)

    pc = sub.add_parser("claims", help="Show active IngestJob claims + stage manifest (G4, read-only).")
    pc.add_argument("--ttl-sec", type=int, default=3600, help="Claim TTL for active/expired split.")
    pc.add_argument("--limit", type=int, default=200, help="Max claims to show.")
    pc.add_argument("--expired", action="store_true", help="Also list expired (reapable) claims.")
    pc.set_defaults(func=cmd_claims)

    prp = sub.add_parser("reap", help="Clear expired IngestJob claims (bounded reaper).")
    prp.add_argument("--ttl-sec", type=int, default=3600)
    prp.add_argument("--limit", type=int, default=200)
    prp.set_defaults(func=cmd_reap)

    pl = sub.add_parser("link-speakers", help="Globally link local Speakers -> GlobalSpeaker.")
    pl.add_argument("--limit", type=int, default=0, help="Process at most N speakers (debug).")
    pl.add_argument("--max-speakers", type=int, default=0, help="Global cap of speakers this run.")
    pl.add_argument("--priority", type=str, default=None, help="Override priority-name regex.")
    pl.add_argument("--faiss", action="store_true", help="Use FAISS local prefilter (wider nets).")
    pl.add_argument("--more-aggressive", action="store_true", help="Wider thresholds/nets.")
    pl.add_argument("--rank-and-label", action="store_true",
                    help="Also run full-graph dominance + Transcription labeling (heavy; final pass only).")
    pl.add_argument("--promote", action="store_true",
                    help="After linking, promote tentative GlobalSpeakers to confirmed by evidence threshold (paged).")
    pl.add_argument("--promote-min-weight", type=float, default=0.0,
                    help="Minimum weight_sum for --promote (0 = use linker default).")
    pl.add_argument("--dry-run", action="store_true", help="Do not write to Neo4j.")
    pl.add_argument("--state-file", type=str, default="",
                   help="JSON file of already-processed speaker IDs for monotonic chunked/resumed runs.")
    pl.set_defaults(func=cmd_link_speakers)

    pr = sub.add_parser("run-all",
                        help="Run the full historical ingest pipeline (machine-agnostic).")
    pr.add_argument("--skip-copy", action="store_true", help="Skip audio/dashcam/bodycam copy.")
    pr.add_argument("--skip-diarize", action="store_true", help="Skip speaker diarization.")
    pr.add_argument("--skip-ingest", action="store_true", help="Skip transcript ingest + reconcile.")
    pr.add_argument("--skip-classify", action="store_true", help="Skip music/lyrics classification.")
    pr.add_argument("--skip-link", action="store_true", help="Skip global speaker linking.")
    pr.add_argument("--skip-yolo", action="store_true", help="Skip dashcam YOLO embeddings.")
    pr.add_argument("--limit", type=int, default=0, help="Linker: process at most N speakers.")
    pr.add_argument("--max-speakers", type=int, default=0, help="Linker: global speaker cap.")
    pr.add_argument("--faiss", action="store_true", help="Linker: use FAISS prefilter.")
    pr.add_argument("--more-aggressive", action="store_true", help="Linker: wider thresholds.")
    pr.add_argument("--rank-and-label", action="store_true",
                    help="Linker: full-graph dominance + labeling (heavy; final pass).")
    pr.add_argument("--promote", action="store_true",
                    help="Linker: promote tentative GlobalSpeakers to confirmed by evidence. ")
    pr.add_argument("--dry-run", action="store_true", help="Linker: do not write to Neo4j.")
    pr.add_argument("--state-file", type=str, default="",
                    help="Linker: resume state file of processed speaker IDs.")
    pr.set_defaults(func=cmd_run_all)

    pw = sub.add_parser("whoami", help="Anchor / verify the 'me' (Scott) speaker.")
    pw.add_argument("--dry-run", action="store_true")
    pw.add_argument("--corpus", type=str, default=None, help="Folder of known-me audio to validate.")
    pw.add_argument("--merge", action="store_true", help="Merge fragmented Scott GlobalSpeakers.")
    pw.add_argument("--seed", type=str, default=None, help="Override Scott GlobalSpeaker id.")
    pw.set_defaults(func=cmd_whoami)

    pt = sub.add_parser("tiktok", help="Generate iPhone TikTok-style vertical shorts from footage.")
    src = pt.add_mutually_exclusive_group(required=True)
    src.add_argument("--clip", help="Source video (e.g. *_FR.MP4)")
    src.add_argument("--source-root", help="Scan a media root and pick a clip")
    src.add_argument("--nextcloud", action="store_true", help="Scan the Nextcloud (iPhone) root for a clip")
    pt.add_argument("--pick", choices=["newest", "random"], default="newest", help="Clip pick when scanning")
    pt.add_argument("--date", default=None, help="Filter scanned clips by YYYY-MM-DD")
    pt.add_argument("--out", required=True, help="Output mp4 path")
    pt.add_argument("--transcript-json", default=None, help="Optional JSON list of {start,end,text}")
    pt.add_argument("--hook", default=None, help="Top hook/title text")
    pt.add_argument("--cta", default="Follow for more", help="Closing CTA text")
    pt.add_argument("--music", default=None, help="Optional background music (looped+ducked)")
    pt.add_argument("--zoom", type=float, default=1.06, help="Slight zoom-punch factor (>1)")
    pt.add_argument("--crf", type=int, default=24, help="H.264 CRF")
    pt.add_argument("--max-dur", type=float, default=60.0, help="Cap short length (seconds)")
    pt.add_argument("--no-auto-transcript", action="store_true",
                    help="Do not fetch transcript from Neo4j")
    pt.set_defaults(func=cmd_tiktok)

    pwk = sub.add_parser("worker", help="Run the idle-gated background worker (speaker-link/compress/content).")
    pwk.set_defaults(func=cmd_worker)

    ps = sub.add_parser("shorts", help="Research-scripted shorts (Neo4j topic + highway B-roll).",
                          add_help=False)
    ps.add_argument("rest", nargs=argparse.REMAINDER, help="Forwarded to auto_ingest.shorts.cli")
    ps.set_defaults(func=cmd_shorts)

    plc = sub.add_parser("link-concepts",
                         help="Link spoken Utterances to research Concepts (W-56).")
    plc.add_argument("rest", nargs=argparse.REMAINDER, help="Forwarded to link_utterances_to_concepts.py")
    plc.set_defaults(func=cmd_link_concepts)

    pi = sub.add_parser("ingest", help="Ingest iPhone movies/pictures (Nextcloud/local) -> graph + content.")
    src = pi.add_mutually_exclusive_group()
    src.add_argument("--root", help="Local media root to scan (e.g. /media/scott/SSD_4TB/photos)")
    src.add_argument("--nextcloud-url", help="Nextcloud WebDAV base URL (live pull)")
    pi.add_argument("--nextcloud-user", help="Nextcloud WebDAV user")
    pi.add_argument("--nextcloud-pass", help="Nextcloud WebDAV password/app-token")
    pi.add_argument("--nextcloud-root", default="Photos",
                    help="Subfolder under the user's files when URL is the bare server root")
    pi.add_argument("--source", default="nextcloud", help="source label for MediaFile nodes")
    pi.add_argument("--kind", choices=["movie", "picture", "all"], default="all")
    pi.add_argument("--state", default="./media_ingest.json", help="Resume state file")
    pi.add_argument("--limit", type=int, default=0, help="Max files this run (0=all)")
    pi.add_argument("--no-transcribe", action="store_true", help="Skip Whisper transcription")
    pi.add_argument("--no-embed", action="store_true", help="Skip CLIP image embedding")
    pi.add_argument("--no-shorts", action="store_true", help="Skip short generation")
    pi.add_argument("--music", default=None, help="Background music for slideshows")
    pi.add_argument("--slideshow", action="store_true", help="Build per-date Ken Burns slideshow shorts")
    pi.add_argument("--force", action="store_true", help="Re-process already-done files")
    pi.add_argument("--dry-run", action="store_true", help="Scan + metadata only, no Neo4j write")
    pi.set_defaults(func=cmd_ingest)

    return p


def main() -> int:
    # Best-effort rotating log setup (O-G8). Never breaks existing stdout output.
    try:
        from tools.setup_logging import setup_logging
        setup_logging(name="auto-ingest")
    except Exception:
        pass
    args = build_parser().parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
